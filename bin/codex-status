#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_status_script="$(cd "$script_dir/.." && pwd)/scripts/host-status.sh"
status_script="${CODEX_HOST_STATUS_SCRIPT:-${HOME}/.codex/host-status.sh}"

if [ ! -x "$status_script" ] && [ -x "$repo_status_script" ]; then
    status_script="$repo_status_script"
fi

find_real_codex() {
    local candidate resolved self wrapper

    if [ -n "${CODEX_REAL_BIN:-}" ]; then
        printf '%s\n' "$CODEX_REAL_BIN"
        return 0
    fi

    self=$(readlink -f "$0" 2>/dev/null || printf '%s' "$0")
    wrapper="${HOME}/.local/bin/codex"

    while IFS= read -r candidate; do
        [ -n "$candidate" ] || continue
        resolved=$(readlink -f "$candidate" 2>/dev/null || printf '%s' "$candidate")
        [ "$resolved" = "$self" ] && continue
        if [ "$candidate" = "$wrapper" ] && grep -q 'codex-status' "$candidate" 2>/dev/null; then
            continue
        fi
        printf '%s\n' "$candidate"
        return 0
    done < <(type -aP codex 2>/dev/null || true)

    for candidate in "$script_dir"/codex.bak.* /usr/local/bin/codex /opt/homebrew/bin/codex /usr/bin/codex; do
        [ -x "$candidate" ] || continue
        resolved=$(readlink -f "$candidate" 2>/dev/null || printf '%s' "$candidate")
        [ "$resolved" = "$self" ] && continue
        printf '%s\n' "$candidate"
        return 0
    done

    return 1
}

real_codex=$(find_real_codex || true)
if [ -z "$real_codex" ]; then
    printf 'codex-status: could not find the real Codex binary. Set CODEX_REAL_BIN=/path/to/codex.\n' >&2
    exit 127
fi
if [ ! -x "$real_codex" ]; then
    printf 'codex-status: real Codex binary is not executable: %s\n' "$real_codex" >&2
    exit 126
fi

case "${1:-}" in
    exec|review|doctor|sandbox|debug|mcp|plugin|login|logout|completion|update|apply|archive|delete|unarchive|mcp-server|app-server|exec-server|features|help|-h|--help|-V|--version)
        exec "$real_codex" "$@"
        ;;
esac

configure_tmux_status() {
    local target="$1"
    local interval="${CODEX_STATUS_INTERVAL:-5}"
    local left_length="${CODEX_STATUS_LEFT_LENGTH:-180}"
    local mouse="${CODEX_STATUS_MOUSE:-off}"

    case "$mouse" in
        on|off) ;;
        true|1|yes) mouse="on" ;;
        false|0|no) mouse="off" ;;
        *)
            printf 'codex-status: invalid CODEX_STATUS_MOUSE=%s; expected on/off\n' "$mouse" >&2
            mouse="off"
            ;;
    esac

    tmux set-option -t "$target" status on >/dev/null
    tmux set-option -t "$target" status-interval "$interval" >/dev/null
    tmux set-option -t "$target" status-position bottom >/dev/null
    tmux set-option -t "$target" status-style 'bg=colour235,fg=colour250' >/dev/null
    tmux set-option -t "$target" mouse "$mouse" >/dev/null
    tmux set-option -t "$target" history-limit "${CODEX_STATUS_HISTORY_LIMIT:-50000}" >/dev/null
    tmux set-option -t "$target" status-left "#(CODEX_STATUS_COLUMNS='#{client_width}' CODEX_STATUS_CWD='#{pane_current_path}' ${status_script} --tmux)" >/dev/null
    tmux set-option -t "$target" status-right '' >/dev/null
    tmux set-option -t "$target" status-left-length "$left_length" >/dev/null
    tmux set-option -t "$target" status-right-length 0 >/dev/null
    tmux set-window-option -t "${target}:" window-status-format '' >/dev/null
    tmux set-window-option -t "${target}:" window-status-current-format '' >/dev/null
}

quote_cmd() {
    local quoted="" q=""
    for arg in "$@"; do
        printf -v q '%q' "$arg"
        quoted+="${q} "
    done
    printf '%s' "$quoted"
}

if [ "${CODEX_STATUS_TMUX:-1}" = "0" ]; then
    exec "$real_codex" "$@"
fi

codex_args=("$@")
if [ "${CODEX_STATUS_NO_ALT_SCREEN:-1}" != "0" ]; then
    has_no_alt_screen=false
    for arg in "${codex_args[@]}"; do
        if [ "$arg" = "--no-alt-screen" ]; then
            has_no_alt_screen=true
            break
        fi
    done
    if [ "$has_no_alt_screen" = false ]; then
        codex_args=("--no-alt-screen" "${codex_args[@]}")
    fi
fi

if [ ! -t 0 ] || [ ! -t 1 ] || ! command -v tmux >/dev/null 2>&1; then
    exec "$real_codex" "$@"
fi

if [ -n "${TMUX:-}" ]; then
    current_session=$(tmux display-message -p '#S')
    configure_tmux_status "$current_session"
    exec "$real_codex" "${codex_args[@]}"
fi

base=$(basename "${PWD:-codex}" | tr -cd '[:alnum:]_.-' | cut -c1-32)
[ -n "$base" ] || base="codex"
session="codex-${base}-$$"
cmd=$(quote_cmd "$real_codex" "${codex_args[@]}")

tmux new-session -d -s "$session" -c "$PWD" "$cmd"
configure_tmux_status "$session"
tmux attach-session -t "$session"
